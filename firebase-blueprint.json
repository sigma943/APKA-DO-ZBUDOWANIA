{
  "entities": {
    "UserPreference": {
      "title": "User Preference",
      "description": "User specific application settings",
      "type": "object",
      "properties": {
        "mks_filter": {
          "type": "string",
          "description": "Bus line filter"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}/preferences/filters": {
      "schema": {
        "$ref": "UserPreference"
      },
      "description": "User specific app filters"
    }
  }
}
